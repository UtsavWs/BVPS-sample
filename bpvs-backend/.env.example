PORT=5000

# Cloudinary (for image deletion — get API Key & Secret from your Cloudinary dashboard)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
MONGO_URI=mongodb://localhost:27017/bpvs
JWT_SECRET=change_me_to_a_random_secret
JWT_EXPIRE=7d
OTP_EXPIRE_MINUTES=5

# Nodemailer (Gmail — use an App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
# IMPORTANT: EMAIL_FROM address MUST match EMAIL_USER, otherwise emails go to spam
EMAIL_FROM="BPVS <your_email@gmail.com>"
